# Variáveis de Ambiente para Render

# Debug Mode (False em produção, True em desenvolvimento)
DEBUG=False

# Database URL do PostgreSQL (fornecido pelo Render)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Variáveis de Segurança (adicionar no Render)
SECRET_KEY=sua-secret-key-aqui
ALLOWED_HOSTS=seu-app.onrender.com
